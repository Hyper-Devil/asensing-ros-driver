<launch>

  <arg name="debug_display" default="false"/>

  <node pkg="asensing-ros-driver" type="asensing_node" name="asensing_node" required="true" output="screen">
    <param name="port" value="/dev/ttyUSB0"/>
    <param name="buadrate" type="int" value="460800"/>
    <param name="device_model" type="str" value="ins5711daa"/>
    <param name="frame_id" type="str" value="imu_link"/>
    <param name="gravity_acceleration" type="double" value="9.7883105"/>
    <param name="use_gps_time" type="bool" value="true"/>
    <param name="debug_display" type="bool" value="$(arg debug_display)"/>
    <param name="broadcast_tf" type="bool" value="false"/>
  </node>

  <!-- <node pkg="rviz" type="rviz" name="rviz" args="-d $(find asensing)/rviz/demo.rviz" required="true"/> -->

</launch>
