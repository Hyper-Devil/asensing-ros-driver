<launch>

  <node pkg="asensing-ros-driver" type="asensing_node" name="asensing_node" required="true" output="screen">
    <param name="port" value="/dev/ttyUSB0"/>
    <param name="buadrate" type="int" value="230400"/>
    <param name="device_model" type="str" value="ins570d"/>
    <param name="frame_id" type="str" value="base_link"/>
    <param name="gravity_acceleration" type="double" value="9.7883105"/>
    <param name="use_gps_time" type="bool" value="false"/>
    <param name="broadcast_tf" type="bool" value="true"/>
    <param name="tf_parent_frame_id" type="str" value="world"/>
    <param name="tf_frame_id" type="str" value="base_link"/>
  </node>

  <!-- <node pkg="rviz" type="rviz" name="rviz" args="-d $(find asensing)/rviz/demo.rviz" required="true"/> -->

</launch>
